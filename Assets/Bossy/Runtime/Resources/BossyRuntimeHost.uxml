<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="host-root" style="width: 100%; height: 100%; flex-direction: column; background-color: rgb(23, 29, 51);">
        <ui:VisualElement name="ribbon" style="flex-direction: row; align-items: center; padding: 4px; border-bottom-width: 1px; background-color: rgb(24, 28, 34);">
            <ui:VisualElement name="tab-strip" style="flex-direction: row; flex-grow: 1; align-items: center;"/>
            <ui:Button name="btn-minimize" text="—" tooltip="Minimize"/>
        </ui:VisualElement>
        <ui:VisualElement name="content-area" style="flex-grow: 1; width: 100%;"/>
    </ui:VisualElement>
</ui:UXML>
